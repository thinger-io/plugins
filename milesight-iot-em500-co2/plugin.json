        "description": "Milesight EM500-CO2 measures CO2, temperature, humidity, and barometric pressure in harsh environments. Ideal for greenhouses, wine cellars, building ventilation, and fruit/vegetable storage where monitoring CO2 levels is critical.",
        "enabled": true,
        "name": "Milesight-Iot EM500-CO2",
        "product": "milesight_iot_em500_co2",
        "profile": {
          "api": {
            "downlink": {
              "enabled": true,
              "handle_connectivity": false,
              "request": {
                "data": {
                  "path": "/downlink",
                  "payload": "{\r\n    \"data\"    : \"{{payload.data=\"\"}}\",\r\n    \"port\"    :  {{payload.port=2}},\r\n    \"priority\":  {{payload.priority=3}},\r\n    \"confirmed\" :  {{payload.confirmed=false}},\r\n    \"uplink\"  :  {{property.uplink}} \r\n}",
                  "payload_function": "",
