            {
                "description": "Milesight AM104 is a compact indoor ambience monitoring sensor that supports long-lasting battery life, wall-mounted installation, and visual display via an E-ink screen. It's equipped with NFC and can easily be configured via a smartphone or PC software.",
                "enabled": true,
                "name": "Milesight-Iot AM104",
                "product": "milesight_iot_am104",
                "profile": {
                    "api": {
                        "downlink": {
                            "enabled": true,
                            "handle_connectivity": false,
                            "request": {
